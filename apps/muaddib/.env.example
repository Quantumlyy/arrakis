# Copy to .env.local and fill in.

# ---- Better Auth ----
# Session/cookie secret — generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=

# Public URL of this app. In dev, leave as http://localhost:3000.
BETTER_AUTH_URL=http://localhost:3000

# Mirror of BETTER_AUTH_URL exposed to the client bundle.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# SQLite file path for dev. Defaults to .data/muaddib.sqlite under cwd.
# BETTER_AUTH_DB_PATH=.data/muaddib.sqlite

# ---- Dune (anonymous demo path) ----
# Dune API key for the anonymous demo path. Grab one from
# https://dune.com/settings/api — the muaddib demo uses API-key auth for the
# shared ISR-cached page. Per-user OAuth (via @arrakis/fremen) is layered on
# top of this demo once a visitor logs in and connects their own Dune account.
DUNE_API_KEY=

# Override the MCP endpoint if Dune moves it.
DUNE_MCP_URL=https://api.dune.com/mcp/v1

# A saved Dune query id the demo page will execute on page load.
DUNE_QUERY_ID=
