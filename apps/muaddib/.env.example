# Copy to .env.local and fill in.
# The demo owner's long-lived Dune OAuth access token. Post-interview this
# moves to per-user OAuth via @arrakis/fremen.
DUNE_ACCESS_TOKEN=

# Override the MCP endpoint if Dune moves it.
DUNE_MCP_URL=https://api.dune.com/mcp/v1

# A saved Dune query id the demo page will execute on page load.
DUNE_QUERY_ID=
