{
  "name": "@arrakis/fremen",
  "version": "0.0.0",
  "private": true,
  "description": "Better Auth plugin + React components for connecting Dune accounts. The people who use the spice.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./react/styles.css": "./src/react/styles.css"
  },
  "files": ["dist", "src/react/styles.css"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@arrakis/spice": "workspace:*",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "better-auth": "^1.6.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "better-auth": "^1.2.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
